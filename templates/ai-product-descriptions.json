            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1b2c3d4-0004-4000-8000-000000000004",
      "name": "Only products without a description",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [920, 60]
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "mode": "list",
          "value": "gpt-4o-mini",
          "cachedResultName": "gpt-4o-mini"
        },
        "messages": {
          "values": [
            {
              "content": "=You are an ecommerce copywriter who writes product descriptions that convert without sounding like ads.\n\nWrite a product description for the following product.\n\nProduct name: {{ $json['Product Name'] }}\nKey features: {{ $json.Features }}\nTone: {{ $json.Tone || 'friendly and confident' }}\n\nRules:\n- 2 short paragraphs, 60-110 words total.\n- Lead with the customer benefit, not the product.\n- Weave in the key features naturally - never as a list.\n- No clichés (\"game-changer\", \"elevate\", \"unleash\"), no exclamation marks, no emojis.\n- Write in the requested tone.\n- Return ONLY the description text, nothing else.",
              "role": "user"
            }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0005-4000-8000-000000000005",
      "name": "Write description (AI)",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [1160, 40]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "set-name",
              "name": "Product Name",
              "value": "={{ $('Only products without a description').item.json['Product Name'] }}",
              "type": "string"
            },
            {
              "id": "set-desc",
              "name": "AI Description",
              "value": "={{ $json.message.content }}",
              "type": "string"
            },
            {
              "id": "set-date",
