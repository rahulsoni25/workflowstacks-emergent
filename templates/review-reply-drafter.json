      "id": "b2c3d4e5-0004-4000-8000-000000000004",
      "name": "Only reviews without a reply",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [920, 60]
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "mode": "list",
          "value": "gpt-4o-mini",
          "cachedResultName": "gpt-4o-mini"
        },
        "messages": {
          "values": [
            {
              "content": "=You reply to customer reviews on behalf of a small ecommerce brand. You sound like a real, caring human — never corporate, never scripted.\n\nDraft a reply to this review:\n\nCustomer: {{ $json['Customer Name'] }}\nRating: {{ $json.Rating }} / 5\nReview: {{ $json.Review }}\n\nRules:\n- 2-4 sentences. Address the customer by first name.\n- 4-5 stars: thank them specifically for what they praised — mirror their words, don't be generic.\n- 3 stars or below: acknowledge the specific problem first, apologize once sincerely, state one concrete thing you'll do (replacement, refund contact, fix), and invite them to email support. Never argue, never make excuses, never blame the customer or shipping.\n- No emojis, no exclamation-mark pileups, no \"we're sorry you feel that way\".\n- Return ONLY the reply text.",
              "role": "user"
            }
          ]
        },
        "options": {}
      },
      "id": "b2c3d4e5-0005-4000-8000-000000000005",
      "name": "Draft reply (AI)",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [1160, 40]
    },
